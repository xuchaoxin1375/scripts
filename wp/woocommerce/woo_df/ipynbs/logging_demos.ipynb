    "import logging\n",
    "\n",
    "# 配置日志格式，包含函数名\n",
    "logging.basicConfig(\n",
    "    level=logging.DEBUG,\n",
    "    format=\"%(asctime)s [%(levelname)s] %(funcName)s: %(message)s\"\n",
    ")\n",
    "\n",
    "def example_function():\n",
    "    logging.debug(\"这是一个调试日志\")\n",
    "\n",
    "example_function()"
