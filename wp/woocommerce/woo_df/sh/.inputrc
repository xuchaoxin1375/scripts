# 可以通过bind -f ~/.inputrc的方式激活或重载配置.
# 配置生效排查:bind -v | grep "变量名" #部分环境下导入此配置并不生效

# ==切换到 vi 编辑模式（如果你是键盘侠）
# set editing-mode vi

# ==基础全局设置
$include /etc/inputrc
set editing-mode emacs
set show-all-if-ambiguous on    # 按一下 Tab 就显示所有补全结果
set completion-ignore-case on   # 补全忽略大小写
set completion-map-case on      # 输入错误时，按下 Tab 自动更正（类似 Zsh 的模糊匹配）
set mark-directories on         # 补全目录时自动加上斜杠 /
set visible-stats on            # 补全列表显示文件类型标识（如 * @ /）


# ==搜索增强 (历史记录快速搜索)
# 输入命令开头再按上下键，只在匹配的历史中搜索
"\e[A": history-search-backward
"\e[B": history-search-forward

# ==颜色与美化 (如果系统支持)
set colored-stats on            # 补全列表显示颜色
set colored-completion-prefix on # 补全时高亮匹配的部分

# ==快捷键微调(注意shopt的配置不要放在这个文件里，要放在.bashrc或被导入其中)
# 第一次按 Tab 补全共有部分，第二次按才开始循环
set menu-complete-display-prefix on

         
# 允许按下 Tab 时直接在候选项中循环切换
"\C-i": menu-complete

# 如果你还希望 Shift+Tab 可以反向切换（向后跳）
"\e[Z": menu-complete-backward


# Ctrl+Delete 删除光标后的单词
"\e[3;5~": kill-word
# Ctrl+Backspace 删除光标前的单词
"\C-H": backward-kill-word

# END(下面保留一个空行避免尾部换行符错误)
