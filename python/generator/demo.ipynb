    "def gen_demo():\n",
    "    cnt = 0\n",
    "    val=1\n",
    "    while cnt <= 5:\n",
    "        val = yield cnt\n",
    "        cnt += val\n",
    "gen=gen_demo()\n",
    "print(next(gen))"
